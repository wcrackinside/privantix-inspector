{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://privantix-source-inspector/output/acl-audit-result",
  "title": "Privantix ACL Audit Result",
  "description": "Output schema for privantix-acl-audit command",
  "type": "object",
  "required": ["started_at", "completed_at", "path", "output_dir", "total_dirs", "dirs"],
  "properties": {
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "duration_seconds": { "type": "number" },
    "path": { "type": "string" },
    "output_dir": { "type": "string" },
    "total_dirs": { "type": "integer" },
    "trusted_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "members"],
        "properties": {
          "name": { "type": "string" },
          "members": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "offboarded_users": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of offboarded principals (usuarios de bajas) used for detection"
    },
    "dirs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "name", "depth", "owner", "permissions", "acls"],
        "properties": {
          "path": { "type": "string" },
          "name": { "type": "string" },
          "depth": { "type": "integer" },
          "owner": { "type": "string" },
          "permissions": { "type": "string" },
          "acls": { "type": "array", "items": { "type": "string" } },
          "trusted_principals": { "type": "array", "items": { "type": "string" } },
          "outside_principals": { "type": "array", "items": { "type": "string" } },
          "compliance_status": { "type": "string", "enum": ["compliant", "non_compliant"] },
          "offboarded_principals": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Principals present in ACLs that match offboarded_users (usuarios de bajas)"
          },
          "has_offboarded_principals": {
            "type": "boolean",
            "description": "True if at least one offboarded principal has access to this directory"
          }
        }
      }
    },
    "errors": { "type": "array", "items": { "type": "string" } }
  }
}
