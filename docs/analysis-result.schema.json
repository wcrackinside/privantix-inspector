{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://privantix-source-inspector/output/analysis-result",
  "title": "Privantix Inspector Analysis Result",
  "description": "Output schema for privantix-inspector scan command",
  "type": "object",
  "required": ["run", "files", "errors"],
  "properties": {
    "run": {
      "type": "object",
      "required": ["started_at", "completed_at", "path", "output_dir", "supported_files", "analyzed_files", "failed_files"],
      "properties": {
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "path": { "type": "string" },
        "output_dir": { "type": "string" },
        "supported_files": { "type": "integer" },
        "analyzed_files": { "type": "integer" },
        "failed_files": { "type": "integer" },
        "max_sample_rows": { "type": "integer" },
        "workers": { "type": "integer" },
        "supported_extensions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "name": { "type": "string" },
          "extension": { "type": "string" },
          "size_bytes": { "type": "integer" },
          "modified_at": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "depth": { "type": "integer" },
          "owner": { "type": "string" },
          "permissions": { "type": "string" },
          "acls": { "type": "array", "items": { "type": "string" } },
          "trusted_principals": { "type": "array", "items": { "type": "string" } },
          "outside_principals": { "type": "array", "items": { "type": "string" } },
          "compliance_status": { "type": "string", "enum": ["compliant", "non_compliant"] },
          "checksum": { "type": "string" },
          "encoding": { "type": "string" },
          "delimiter": { "type": "string" },
          "has_header": { "type": "boolean" },
          "row_count_estimate": { "type": "integer" },
          "column_count": { "type": "integer" },
          "average_row_width": { "type": "integer" },
          "sheet_name": { "type": "string" },
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file_path": { "type": "string" },
                "sheet_name": { "type": "string" },
                "name": { "type": "string" },
                "position": { "type": "integer" },
                "inferred_type": { "type": "string", "enum": ["string", "integer", "float", "boolean", "date", "datetime", "email", "phone", "id_like"] },
                "null_percentage": { "type": "number" },
                "max_length": { "type": "integer" },
                "sample_values": { "type": ["array", "null"], "items": { "type": "string" } }
              }
            }
          },
          "rules_triggered": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "rule_name": { "type": "string" },
                "severity": { "type": "string" },
                "message": { "type": "string" },
                "target": { "type": "string" }
              }
            }
          },
          "errors": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
